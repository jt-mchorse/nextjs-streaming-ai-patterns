# Optional. If unset, every demo falls back to a committed mock streamer so the
# repo runs on a fresh clone without an Anthropic account. The page surfaces
# which mode is active in the footer.
ANTHROPIC_API_KEY=

# Optional. Pin the model used by the demos. Default: claude-haiku-4-5-20251001.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
